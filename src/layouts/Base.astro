---
// Self-hosted variable fonts (Fontsource) — no external requests, no FOUT.
import "@fontsource-variable/fraunces";
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";
import "../styles/tokens.css";
import "../styles/global.css";
import { site } from "../data/site";

export interface Props {
  title: string;
  description: string;
  /** Path beginning with "/" — used for canonical + og:url */
  path?: string;
  ogImage?: string;
  /** Extra JSON-LD objects to inject for this page */
  jsonLd?: Record<string, unknown>[];
}

const {
  title,
  description,
  path = "/",
  ogImage = "/og.png",
  jsonLd = [],
} = Astro.props;

const canonical = new URL(path, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;

// Organization + LocalBusiness structured data (claude-seo: local SEO + E-E-A-T)
const orgLd = {
  "@context": "https://schema.org",
  "@type": ["Organization", "LocalBusiness", "ElectricalContractor"],
  "@id": `${Astro.site}#organization`,
  name: site.name,
  legalName: site.legalName,
  url: Astro.site?.href,
  email: site.email,
  telephone: site.phones[0].e164,
  description: site.metaDescription,
  slogan: site.tagline,
  knowsAbout: site.products.map((p) => p),
  address: {
    "@type": "PostalAddress",
    streetAddress: site.office.street,
    addressLocality: "Kolkata",
    addressRegion: "West Bengal",
    postalCode: site.office.postalCode,
    addressCountry: "IN",
  },
  areaServed: site.statesServed.map((s) => ({ "@type": "State", name: s })),
  hasCredential: {
    "@type": "EducationalOccupationalCredential",
    credentialCategory: "certification",
    name: "ISO 9001:2015",
  },
  contactPoint: {
    "@type": "ContactPoint",
    telephone: site.phones[0].e164,
    contactType: "sales",
    email: site.email,
    areaServed: "IN",
    availableLanguage: ["en", "hi", "bn"],
  },
};

const allLd = [orgLd, ...jsonLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0d1a2b" />
    <meta name="format-detection" content="telephone=yes" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_IN" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Icons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(allLd)}
    />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />

    <!-- Scroll reveal: IntersectionObserver, staggered, GPU-only transforms. -->
    <script>
      const items = document.querySelectorAll<HTMLElement>("[data-reveal]");
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (reduce || !("IntersectionObserver" in window)) {
        items.forEach((el) => el.classList.add("is-in"));
      } else {
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const el = entry.target as HTMLElement;
              const group = el.closest<HTMLElement>("[data-reveal-group]");
              const sibs = group
                ? Array.from(group.querySelectorAll<HTMLElement>("[data-reveal]"))
                : [el];
              const idx = sibs.indexOf(el);
              // 60ms stagger, capped so late items never feel slow.
              el.style.setProperty("--reveal-delay", `${Math.min(idx, 6) * 60}ms`);
              el.classList.add("is-in");
              obs.unobserve(el);
            });
          },
          { rootMargin: "0px 0px -12% 0px", threshold: 0.12 }
        );
        items.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
