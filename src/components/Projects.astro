---
import { fountainProjects, installations, fountainNote } from "../data/projects";
import { site } from "../data/site";
import Icon from "./Icon.astro";

const [hero, ...rest] = fountainProjects;
---

<section class="section projects" id="projects">
  <div class="shell">
    <header class="phead">
      <span class="phead__num mono">03</span>
      <h2 class="phead__title">Special <em>projects</em></h2>
      <p class="phead__note">
        Control systems for musical fountains, and panels installed across six states.
      </p>
    </header>

    <div class="feature">
      <figure class="shot shot--hero" data-reveal>
        <div class="shot__frame">
          <img
            src={hero.image}
            alt={`${hero.name}, ${hero.place}, musical fountain control by Lite Metal Industries`}
            loading="lazy"
            decoding="async"
            width="1400"
            height="1000"
          />
        </div>
        <figcaption class="shot__cap">
          <span class="shot__place mono">{hero.place} <span>·</span> {hero.state}</span>
          <span class="shot__name">{hero.name}</span>
          <span class="shot__scope">{hero.scope}</span>
        </figcaption>
      </figure>

      <blockquote class="note" data-reveal style="--reveal-delay:80ms">
        <p>{fountainNote}</p>
      </blockquote>
    </div>

    <ul class="row" data-reveal-group>
      {
        rest.map((p) => (
          <li class="shot" data-reveal>
            <div class="shot__frame">
              <img
                src={p.image}
                alt={`${p.name}, ${p.place}, fountain control by Lite Metal Industries`}
                loading="lazy"
                decoding="async"
                width="900"
                height="640"
              />
            </div>
            <figcaption class="shot__cap">
              <span class="shot__place mono">{p.place} <span>·</span> {p.state}</span>
              <span class="shot__name shot__name--sm">{p.name}</span>
              <span class="shot__scope">{p.scope}</span>
            </figcaption>
          </li>
        ))
      }
    </ul>

    <div class="foot">
      <div class="installs" data-reveal>
        <p class="eyebrow eyebrow--navy">Panel installations</p>
        <ul class="installs__list">
          {
            installations.map((it) => (
              <li class="install">
                <Icon name="check" size={16} class="install__tick" />
                <span class="install__name">{it.name}</span>
                <span class="install__place mono">{it.place}, {it.state}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footprint" data-reveal style="--reveal-delay:80ms">
        <p class="eyebrow eyebrow--navy">Delivered across</p>
        <ul class="states">
          {site.statesServed.map((s) => <li class="state mono">{s}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .projects {
    background: var(--navy);
    color: var(--on-navy);
  }

  .phead {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--navy-line);
    margin-bottom: clamp(2.5rem, 1.5rem + 3vw, 4rem);
  }
  .phead__num {
    font-size: var(--fs-mono-label);
    letter-spacing: 0.1em;
    color: var(--accent-bright);
    padding-top: 0.4em;
  }
  .phead__title {
    color: var(--paper);
    font-size: var(--fs-h2);
    flex: 1;
  }
  .phead__title em {
    font-style: italic;
    font-weight: 380;
    color: var(--accent-bright);
  }
  .phead__note {
    color: var(--on-navy-muted);
    font-size: 0.92rem;
    max-width: 30ch;
  }

  .feature {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(1.5rem, 1rem + 3vw, 2.5rem);
    margin-bottom: clamp(1.5rem, 1rem + 2vw, 2.5rem);
  }

  /* Photo frames */
  .shot {
    list-style: none;
  }
  .shot__frame {
    overflow: hidden;
    border: 1px solid var(--navy-line);
    border-radius: var(--r);
    background: #060d16;
  }
  .shot__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 900ms var(--ease-out);
  }
  .shot--hero .shot__frame {
    aspect-ratio: 4 / 3;
  }
  .row .shot__frame {
    aspect-ratio: 4 / 3;
  }
  @media (hover: hover) and (pointer: fine) {
    .shot:hover .shot__frame img {
      transform: scale(1.04);
    }
  }
  .shot__cap {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 0.9rem;
  }
  .shot__place {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--accent-bright);
    text-transform: uppercase;
  }
  .shot__place span {
    color: var(--on-navy-muted);
  }
  .shot__name {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 420;
    color: var(--paper);
    line-height: 1.1;
  }
  .shot__name--sm {
    font-size: 1.25rem;
  }
  .shot__scope {
    font-size: 0.88rem;
    color: var(--on-navy-muted);
  }

  /* World's-26 pull quote */
  .note {
    border-left: 2px solid var(--accent-bright);
    padding: 0.25rem 0 0.25rem 1.5rem;
    align-self: center;
  }
  .note p {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 380;
    font-style: italic;
    line-height: 1.4;
    color: var(--paper);
    text-wrap: pretty;
  }
  .note__src {
    margin-top: 1rem;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--on-navy-muted);
  }

  .row {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(1.5rem, 1rem + 2vw, 2.25rem);
    margin-bottom: clamp(3rem, 2rem + 3vw, 4.5rem);
  }

  /* Footer block */
  .eyebrow--navy {
    color: var(--accent-bright);
  }
  .foot {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(2rem, 1rem + 4vw, 3.5rem);
    padding-top: clamp(2rem, 1rem + 3vw, 3rem);
    border-top: 1px solid var(--navy-line);
  }
  .installs__list {
    margin-top: 1.1rem;
    display: grid;
    gap: 0.1rem;
  }
  .install {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--navy-line);
  }
  .install__tick {
    color: var(--accent-bright);
  }
  .install__name {
    font-weight: 500;
    color: var(--paper);
  }
  .install__place {
    font-size: 0.78rem;
    color: var(--on-navy-muted);
    text-align: right;
  }
  .states {
    margin-top: 1.1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .state {
    padding: 0.5rem 0.9rem;
    border: 1px solid var(--navy-line);
    border-radius: var(--r-sm);
    font-size: 0.82rem;
    color: var(--on-navy);
  }

  @media (min-width: 760px) {
    .feature {
      grid-template-columns: 1.5fr 1fr;
      align-items: stretch;
    }
    .row {
      grid-template-columns: repeat(3, 1fr);
    }
    .foot {
      grid-template-columns: 1.4fr 1fr;
    }
  }
</style>
