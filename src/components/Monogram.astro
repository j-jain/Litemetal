---
// LM monogram, drawn as geometry so it matches the favicon and needs no font.
export interface Props {
  size?: number;
  tone?: "ink" | "paper";
  withMark?: boolean;
  class?: string;
}
const { size = 36, tone = "ink", withMark = true, class: cls = "" } = Astro.props;
const stroke = tone === "paper" ? "var(--paper)" : "var(--ink)";
const accent = "var(--accent)";
---

<svg
  class={cls}
  width={size}
  height={size}
  viewBox="0 0 64 64"
  fill="none"
  role="img"
  aria-label="Lite Metal Industries"
>
  {withMark && <rect width="64" height="64" rx="12" fill="var(--navy)" />}
  <g
    stroke={withMark ? "var(--paper)" : stroke}
    stroke-width="4.4"
    stroke-linecap="square"
  >
    <path d="M 16.6 17.9 V 46.1 H 29.4" />
    <path d="M 34.6 46.1 V 17.9 L 42.2 33.3 L 49.9 17.9 V 46.1" />
  </g>
  <rect
    x="20"
    y={withMark ? 50 : 50}
    width="24"
    height="2.6"
    fill={accent}
  />
</svg>
