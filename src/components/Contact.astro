---
import { site } from "../data/site";
import Icon from "./Icon.astro";

const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(site.office.mapsQuery)}&output=embed`;
---

<section class="section contact" id="contact">
  <div class="shell">
    <header class="phead">
      <span class="phead__num mono">05</span>
      <h2 class="phead__title">Contact</h2>
    </header>

    <div class="contact__grid">
      <div class="details">
        <h3 class="details__lead">Talk to us about your panel.</h3>
        <p class="details__sub">
          Send a drawing, a single-line diagram or a rough requirement. We come
          back with a build plan and a quote.
        </p>

        <div class="card">
          <span class="card__role mono">{site.partner.role}</span>
          <span class="card__person">{site.partner.name}</span>
          <div class="card__lines">
            {
              site.phones.map((p) => (
                <a href={`tel:${p.e164}`} class="card__link">
                  <Icon name="phone" size={16} /> {p.display}
                </a>
              ))
            }
            <a href={`mailto:${site.email}`} class="card__link">
              <Icon name="mail" size={16} /> {site.email}
            </a>
            <span class="card__link card__link--static">
              <Icon name="phone" size={16} /> {site.landline.display}
              <span class="card__tag mono">landline</span>
            </span>
          </div>
        </div>

        <div class="addresses">
          {
            [site.office, site.factory].map((a) => (
              <address class="addr">
                <span class="addr__label mono">
                  <Icon name="pin" size={15} /> {a.label}
                </span>
                {a.lines.map((l) => <span class="addr__line">{l}</span>)}
              </address>
            ))
          }
        </div>
      </div>

      <form class="form" id="contact-form" novalidate>
        <p class="form__intro mono">Project enquiry</p>

        <div class="field">
          <label for="cf-name">Name</label>
          <input id="cf-name" name="name" type="text" autocomplete="name" required />
          <span class="field__error" data-for="cf-name"></span>
        </div>

        <div class="field">
          <label for="cf-org">Organisation <span class="opt">optional</span></label>
          <input id="cf-org" name="organisation" type="text" autocomplete="organization" />
        </div>

        <div class="field-row">
          <div class="field">
            <label for="cf-email">Email</label>
            <input id="cf-email" name="email" type="email" autocomplete="email" required />
            <span class="field__error" data-for="cf-email"></span>
          </div>
          <div class="field">
            <label for="cf-phone">Phone <span class="opt">optional</span></label>
            <input id="cf-phone" name="phone" type="tel" autocomplete="tel" />
          </div>
        </div>

        <div class="field">
          <label for="cf-msg">What do you need built?</label>
          <textarea id="cf-msg" name="message" rows="4" required></textarea>
          <span class="field__error" data-for="cf-msg"></span>
        </div>

        <!-- honeypot for bots -->
        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hp" aria-hidden="true" />

        <button type="submit" class="btn btn--on-navy form__submit">
          Send enquiry
          <Icon name="arrow-right" size={18} class="btn__arrow" />
        </button>
        <p class="form__status" role="status" aria-live="polite"></p>
        <p class="form__fallback">
          Prefer email? Write to
          <a href={`mailto:${site.email}`} class="tlink">{site.email}</a>.
        </p>
      </form>
    </div>

    <div class="map" data-reveal>
      <iframe
        title="Lite Metal Industries office location, Kolkata"
        src={mapSrc}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--navy);
    color: var(--on-navy);
  }
  .phead {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--navy-line);
    margin-bottom: clamp(2.5rem, 1.5rem + 3vw, 4rem);
  }
  .phead__num {
    font-size: var(--fs-mono-label);
    color: var(--accent-bright);
    padding-top: 0.4em;
  }
  .phead__title {
    color: var(--paper);
    font-size: var(--fs-h2);
  }

  .contact__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(2.5rem, 1rem + 5vw, 4.5rem);
  }

  .details__lead {
    font-size: var(--fs-h3);
    color: var(--paper);
    font-weight: 420;
    max-width: 18ch;
  }
  .details__sub {
    margin-top: 1rem;
    color: var(--on-navy-muted);
    max-width: 40ch;
  }

  .card {
    margin-top: 2rem;
    padding: 1.5rem;
    border: 1px solid var(--navy-line);
    border-radius: var(--r);
    background: rgba(255, 255, 255, 0.02);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .card__role {
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-bright);
  }
  .card__person {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--paper);
  }
  .card__lines {
    margin-top: 0.9rem;
    display: grid;
    gap: 0.55rem;
  }
  .card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--on-navy);
    font-size: 0.98rem;
    transition: color var(--dur) var(--ease-std);
  }
  .card__link :global(svg) {
    color: var(--accent-bright);
    flex: none;
  }
  .card__link--static {
    color: var(--on-navy-muted);
  }
  .card__tag {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--faint);
  }
  @media (hover: hover) and (pointer: fine) {
    a.card__link:hover {
      color: var(--accent-bright);
    }
  }

  .addresses {
    margin-top: 2rem;
    display: grid;
    gap: 1.5rem;
  }
  .addr {
    display: grid;
    gap: 0.2rem;
    font-style: normal;
  }
  .addr__label {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-bright);
    margin-bottom: 0.3rem;
  }
  .addr__line {
    color: var(--on-navy);
    font-size: 0.96rem;
  }

  /* ---- Form ---- */
  .form {
    border: 1px solid var(--navy-line);
    border-radius: var(--r-lg);
    padding: clamp(1.5rem, 1rem + 2vw, 2.25rem);
    background: rgba(255, 255, 255, 0.018);
    display: grid;
    gap: 1.1rem;
    align-content: start;
  }
  .form__intro {
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-bright);
  }
  .field {
    display: grid;
    gap: 0.4rem;
  }
  .field-row {
    display: grid;
    gap: 1.1rem;
    /* Don't stretch the optional-phone field to the email field's height
       (email is taller because of its error row) — keep inputs top-aligned
       and at their natural height. */
    align-items: start;
  }
  .field label {
    font-size: 0.82rem;
    color: var(--on-navy-muted);
  }
  .opt {
    color: var(--faint);
    font-size: 0.74rem;
  }
  .field input,
  .field textarea {
    font-family: var(--font-sans);
    font-size: 0.98rem;
    color: var(--paper);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--navy-line);
    border-radius: var(--r-sm);
    padding: 0.75rem 0.85rem;
    transition: border-color var(--dur) var(--ease-std),
      background-color var(--dur) var(--ease-std);
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--accent-bright);
    background: rgba(255, 255, 255, 0.06);
  }
  .field textarea {
    resize: vertical;
    min-height: 6rem;
  }
  .field--invalid input,
  .field--invalid textarea {
    border-color: #d98b8b;
  }
  .field__error {
    font-size: 0.78rem;
    color: #e7a4a4;
    min-height: 1em;
  }
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
  .form__submit {
    justify-self: start;
    margin-top: 0.3rem;
  }
  .form__status {
    font-size: 0.88rem;
    color: var(--accent-bright);
    min-height: 1em;
  }
  .form__fallback {
    font-size: 0.86rem;
    color: var(--on-navy-muted);
  }

  /* ---- Map ---- */
  .map {
    margin-top: clamp(3rem, 2rem + 4vw, 5rem);
    border: 1px solid var(--navy-line);
    border-radius: var(--r);
    overflow: hidden;
    line-height: 0;
  }
  .map iframe {
    width: 100%;
    height: clamp(280px, 30vw, 420px);
    border: 0;
    filter: grayscale(0.3) contrast(1.05);
  }

  @media (min-width: 820px) {
    .contact__grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
    .field-row {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  if (form) {
    const status = form.querySelector<HTMLElement>(".form__status")!;
    const EMAIL = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    const setError = (id: string, msg: string) => {
      const field = document.getElementById(id)!.closest(".field")!;
      const err = form.querySelector<HTMLElement>(`[data-for="${id}"]`);
      field.classList.toggle("field--invalid", !!msg);
      if (err) err.textContent = msg;
    };

    const val = (id: string) =>
      (document.getElementById(id) as HTMLInputElement).value.trim();

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      // honeypot
      if ((form.querySelector<HTMLInputElement>(".hp")?.value || "") !== "") return;

      let ok = true;
      if (!val("cf-name")) { setError("cf-name", "Please tell us your name."); ok = false; }
      else setError("cf-name", "");
      if (!EMAIL.test(val("cf-email"))) { setError("cf-email", "Enter a valid email address."); ok = false; }
      else setError("cf-email", "");
      if (val("cf-msg").length < 8) { setError("cf-msg", "A line or two about the job helps."); ok = false; }
      else setError("cf-msg", "");

      if (!ok) {
        form.querySelector<HTMLElement>(".field--invalid input, .field--invalid textarea")?.focus();
        return;
      }

      const btn = form.querySelector<HTMLButtonElement>(".form__submit")!;
      btn.disabled = true;
      status.textContent = "Sending…";

      try {
        const res = await fetch("https://formspree.io/f/mdardlan", {
          method: "POST",
          headers: { Accept: "application/json" },
          body: new FormData(form),
        });
        const data = await res.json();
        if (res.ok) {
          status.textContent = "Enquiry sent — we'll be in touch shortly.";
          form.reset();
        } else {
          const msg = data?.errors?.map((e: { message: string }) => e.message).join(", ") || "Something went wrong.";
          status.textContent = msg;
          btn.disabled = false;
        }
      } catch {
        status.textContent = "Network error — please try again or email us directly.";
        btn.disabled = false;
      }
    });
  }
</script>
