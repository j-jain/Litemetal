---
import { products } from "../data/products";
---

<section class="section section--alt" id="products">
  <div class="shell">
    <header class="section-head">
      <span class="section-head__num">02</span>
      <h2 class="section-head__title">Products &amp; <em>services</em></h2>
    </header>

    <ul class="grid" data-reveal-group>
      {
        products.map((p, i) => (
          <li class={`item${p.feature ? " is-feature" : ""}`} data-reveal>
            <div class="item__tile">
              <span class="item__idx mono">{String(i + 1).padStart(2, "0")}</span>
              {
                p.image ? (
                  <img
                    class="item__img"
                    src={p.image}
                    alt={`${p.name} manufactured by Lite Metal Industries`}
                    loading="lazy"
                    decoding="async"
                    width="820"
                    height="820"
                  />
                ) : (
                  <svg class="item__schema" viewBox="0 0 200 150" fill="none" aria-hidden="true">
                    <rect x="34" y="34" width="132" height="82" stroke="currentColor" stroke-width="2" />
                    <rect x="46" y="46" width="108" height="58" stroke="currentColor" stroke-width="1" stroke-dasharray="4 4" />
                    <path d="M46 64h108M46 82h108M70 46v58M100 46v58M130 46v58" stroke="currentColor" stroke-width="1" />
                    <path d="M34 28v-8h132v8M34 122v8h132v-8" stroke="currentColor" stroke-width="1.5" />
                  </svg>
                )
              }
            </div>
            <div class="item__body">
              <span class="item__cat mono">{p.category}</span>
              <h3 class="item__name">{p.name}</h3>
              <p class="item__blurb">{p.blurb}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .section--alt {
    background: var(--paper-alt);
    border-block: 1px solid var(--hairline);
  }
  .section-head__note {
    align-self: end;
    font-size: 0.9rem;
    color: var(--muted);
    padding-bottom: 0.4rem;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 1rem + 3vw, 3.25rem) clamp(1.5rem, 1rem + 2vw, 2.5rem);
  }

  .item__tile {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--paper);
    border: 1px solid var(--hairline);
    border-radius: var(--r);
    display: grid;
    place-items: center;
    padding: clamp(1.25rem, 1rem + 2vw, 2.5rem);
    overflow: hidden;
    transition: border-color var(--dur) var(--ease-std),
      transform var(--dur) var(--ease-out);
  }
  .item__idx {
    position: absolute;
    top: 0.85rem;
    left: 1rem;
    font-size: 0.7rem;
    color: var(--faint);
    z-index: 1;
  }
  .item__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform var(--dur-reveal) var(--ease-out);
  }
  .item__schema {
    width: 70%;
    color: var(--hairline-strong);
  }
  .item__body {
    margin-top: 1.1rem;
  }
  .item__cat {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-ink);
  }
  .item__name {
    font-size: var(--fs-h3);
    font-weight: 440;
    margin-top: 0.45rem;
  }
  .item__blurb {
    margin-top: 0.55rem;
    font-size: 0.95rem;
    color: var(--muted);
    max-width: 46ch;
  }

  @media (hover: hover) and (pointer: fine) {
    .item:hover .item__tile {
      border-color: var(--accent);
      transform: translateY(-3px);
    }
    .item:hover .item__img {
      transform: scale(1.03);
    }
  }

  @media (min-width: 620px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 980px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-flow: row dense;
    }
    .item.is-feature {
      grid-column: span 2;
    }
    .item.is-feature .item__tile {
      aspect-ratio: 16 / 9;
    }
  }
</style>
