---
import { site } from "../data/site";
import Monogram from "./Monogram.astro";
import Icon from "./Icon.astro";

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="shell footer__top">
    <div class="footer__brand">
      <a href="#top" class="footer__logo" aria-label={`${site.name} — home`}>
        <Monogram size={44} />
        <span class="footer__name">Lite Metal Industries</span>
      </a>
      <p class="footer__desc">
        Low-tension control panels and control transformers, designed and built
        in Kolkata since the 1990s. ISO 9001:2015 certified.
      </p>
    </div>

    <nav class="footer__col" aria-label="Sections">
      <h2 class="footer__h mono">Explore</h2>
      <ul>
        {site.nav.map((n) => <li><a href={n.href}>{n.label}</a></li>)}
      </ul>
    </nav>

    <div class="footer__col">
      <h2 class="footer__h mono">Reach us</h2>
      <ul>
        <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
        {site.phones.map((p) => <li><a href={`tel:${p.e164}`}>{p.display}</a></li>)}
        <li class="footer__addr">{site.office.lines.join(", ")}</li>
      </ul>
    </div>
  </div>

  <div class="shell footer__bar">
    <p class="footer__copy mono">© {year} {site.name} · Kolkata, India</p>
    <nav class="footer__legal mono" aria-label="Legal">
      <a href="/privacy/">Privacy</a>
      <span aria-hidden="true">·</span>
      <a href="/terms/">Terms</a>
      <span aria-hidden="true">·</span>
      <a href="#top" class="footer__top-link">
        Back to top <Icon name="arrow-up-right" size={14} />
      </a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    background: var(--navy);
    color: var(--on-navy-muted);
    border-top: 1px solid var(--navy-line);
  }
  .footer__top {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2.5rem;
    padding-block: clamp(3rem, 2rem + 3vw, 4.5rem);
  }
  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }
  .footer__name {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--paper);
  }
  .footer__desc {
    margin-top: 1.1rem;
    max-width: 38ch;
    font-size: 0.92rem;
    line-height: 1.6;
  }
  .footer__h {
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-bright);
    margin-bottom: 1rem;
  }
  .footer__col ul {
    display: grid;
    gap: 0.6rem;
  }
  .footer__col a {
    font-size: 0.94rem;
    color: var(--on-navy-muted);
    transition: color var(--dur) var(--ease-std);
  }
  .footer__addr {
    font-size: 0.88rem;
    color: var(--faint);
    max-width: 26ch;
  }
  @media (hover: hover) and (pointer: fine) {
    .footer__col a:hover,
    .footer__legal a:hover {
      color: var(--accent-bright);
    }
  }

  .footer__bar {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    align-items: center;
    padding-block: 1.5rem;
    border-top: 1px solid var(--navy-line);
    font-size: 0.76rem;
  }
  .footer__legal {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .footer__top-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  @media (min-width: 760px) {
    .footer__top {
      grid-template-columns: 1.6fr 1fr 1fr;
      gap: 3rem;
    }
  }
</style>
