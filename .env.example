# Sanity CMS — copy to .env and fill in (see PLAN / setup steps).
# Public: exposed to the build and the embedded Studio at /studio.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Private: used ONLY by `npm run seed` (the one-time migration script).
# Create an Editor token at https://sanity.io/manage → API → Tokens.
# Never commit this. Do NOT set it in Vercel.
SANITY_WRITE_TOKEN=
